# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# Supabase Auth. The VITE_ values are used by the browser client.
# The server also reads them to validate logged-in users before calling Gemini.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Server-only. Required only for scripts/create-test-users.mjs.
# Never expose this in VITE_ variables or client-side code.
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Optional. When set, the app shows a sign-up form and requires this invite code.
# For stronger control, keep this empty and create test users directly in Supabase.
VITE_SIGNUP_INVITE_CODE=""

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Mercado Pago
MERCADO_PAGO_ACCESS_TOKEN="your_mp_access_token"
MERCADO_PAGO_PUBLIC_KEY="your_mp_public_key"
# Secret used to verify webhook signatures (configure in MP dashboard → Notificaciones)
MERCADO_PAGO_WEBHOOK_SECRET="your_mp_webhook_secret"
APP_BASE_URL="https://seu-dominio.vercel.app"

# CORS — the origin of your deployed app (no trailing slash)
ALLOWED_ORIGIN="https://seu-dominio.vercel.app"

# Meta Conversions API (opcional) — evento Purchase server-side no webhook.
# Pixel ID: Gerenciador de Eventos > Fontes de dados. Token: Configuracoes do Pixel > API de Conversoes > Gerar token.
META_PIXEL_ID=""
META_CAPI_ACCESS_TOKEN=""

# Video de onboarding (opcional) — quando definido, o email de boas-vindas
# exibe o botao "Assistir: como usar o PersonalDiet" com este link.
ONBOARDING_VIDEO_URL=""
